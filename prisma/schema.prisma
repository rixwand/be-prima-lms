generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/* =========================
   ENUMS
========================= */

enum UserStatus {
  NOT_VERIFIED
  ACTIVE
  DISABLED
}

enum PublishRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CoursePublishType {
  NEW
  UPDATE
}

enum ApprovalTarget {
  META
  TAGS
  CATEGORY
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum MediaType {
  VIDEO
  IMAGE
  FILE
}

enum MediaStatus {
  PROCESSING
  READY
  BLOCKED
}

/* =========================
   USER & AUTH
========================= */

model User {
  id            Int        @id @default(autoincrement())
  fullName      String
  email         String     @unique
  username      String     @unique
  profilePict   String?    @map("profile_picture")
  passwordHash  String
  status        UserStatus @default(NOT_VERIFIED)
  roleId        Int
  createdAt     DateTime   @default(now())

  role          Role       @relation(fields: [roleId], references: [id])
  coursesOwned  Course[]   @relation("CourseOwner")
  reviewedPublishes CoursePublishRequest[] @relation("ReviewedCourses")
  mediaAssets   MediaAsset[]
  orders        Order[]
  enrollments   Enrollment[]

  @@map("users")
  activationTokens ActivationToken[]
  refreshSessions RefreshSession[]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique

  users User[]
  perms RolePermission[]

  @@map("roles")
}

model RefreshSession {
  jti           String @id
  userId        Int
  expiresAt     DateTime

  revokedAt     DateTime?
  replacedByJti String? @unique @map("replaced_by_jti")

  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  replacedBy    RefreshSession? @relation("SessionChain", fields: [replacedByJti], references: [jti])
  replacedFrom  RefreshSession[] @relation("SessionChain")

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("refresh_session")
}

model ActivationToken {
  id          String @id @default(cuid())
  userId      Int
  selector    String @unique @db.VarChar(64)
  tokenHash   String @map("token_hash") @db.VarChar(64)
  expiresAt   DateTime

  createdAt   DateTime @default(now())
  usedAt      DateTime?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, usedAt])
  @@map("activation_tokens")
}

model Permission {
  id            Int @id @default(autoincrement())
  action        String
  resource      String
  scope         String

  roles         RolePermission[]

  @@unique([scope, action, resource])      
  @@map("permissions")
}

model RolePermission {
  roleId        Int
  permissionId  Int

  role          Role       @relation(fields: [roleId], references: [id])
  permission    Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/* =========================
   CORE COURSE (APPROVED STATE ONLY)
========================= */

model Course {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  ownerId       Int
  publishedAt   DateTime?
  takenDownAt   DateTime?
  takenDownReason String?

  owner         User      @relation("CourseOwner", fields: [ownerId], references: [id])
  sections      CourseSection[]
  discounts     CourseDiscount[]
  publishRequest CoursePublishRequest?
  orders        Order[]
  enrollments   Enrollment[]
  categories    CourseCategory[] @relation("CourseCategories")
  tags          CourseTag[] @relation("CourseTags")

  metaDraft     CourseMetaDraft?
  metaApproved  CourseMetaApproved?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("courses")
}

/* =========================
   COURSE META (TIER B / C)
========================= */

/* Editable by instructor */
model CourseMetaDraft {
  id          Int    @id @default(autoincrement())
  courseId    Int    @unique

  title            String
  shortDescription String
  descriptionJson  Json?
  coverImage       String
  previewVideo     String?
  priceAmount      Int
  isFree           Boolean
  requiresApproval ApprovalTarget[] @default([])

  draftTags        CourseDraftTag[]
  draftCategories  CourseDraftCategory[]
  draftDiscounts   CourseDraftDiscount[]

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("course_meta_drafts")
}

/* Last admin-approved snapshot */
model CourseMetaApproved {
  courseId    Int   @id
  payload     Json
  approvedAt  DateTime

  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_meta_approved")
}

/* =========================
   TAGS & CATEGORIES (TIER C)
========================= */

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique

  courses CourseTag[] @relation("CourseTags")
  coursesDraft CourseDraftTag[]
  @@map("tags")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique

  courses CourseCategory[] @relation("CourseCategories")
  coursesDraft CourseDraftCategory[]
  @@map("categories")
}

model CourseCategory {
  courseId   Int
  categoryId Int
  isPrimary  Boolean @default(false)

  course     Course   @relation("CourseCategories", fields: [courseId], references: [id], onDelete: Cascade)
  category   Category @relation("CourseCategories", fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([courseId, categoryId])
  @@index([categoryId])
  @@map("course_categories")
}

model CourseTag {
  courseId Int
  tagId    Int

  course   Course @relation("CourseTags", fields: [courseId], references: [id], onDelete: Cascade)
  tag      Tag    @relation("CourseTags", fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

model CourseDraftTag {
  draftId Int
  tagId   Int

  draft   CourseMetaDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  tag     Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([draftId, tagId])
  @@map("course_draft_tags")
}

model CourseDraftCategory {
  draftId    Int
  categoryId Int
  isPrimary  Boolean @default(false)

  draft     CourseMetaDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  category  Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([draftId, categoryId])
  @@map("course_draft_categories")
}

/* =========================
   DISCOUNTS (TIER C)
========================= */

model CourseDiscount {
  id        Int @id @default(autoincrement())
  courseId Int

  type      DiscountType
  value     Decimal
  startAt   DateTime?
  endAt     DateTime?
  isActive  Boolean @default(true)
  label     String?

  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_discounts")
}

model CourseDraftDiscount {
  id        Int @id @default(autoincrement())
  draftId  Int

  type      DiscountType
  value     Decimal
  startAt   DateTime?
  endAt     DateTime?
  isActive  Boolean @default(true)
  label     String?

  draft     CourseMetaDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_draft_discounts")
}

/* =========================
   CURRICULUM (TIER A)
========================= */

model CourseSection {
  id        Int @id @default(autoincrement())
  courseId Int
  title     String
  position  Int

  publishedAt DateTime?
  removedAt   DateTime?   

  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@unique([courseId, position])
  @@map("course_sections")
}


model Lesson {
  id          Int @id @default(autoincrement())
  sectionId   Int
  slug        String
  title       String
  summary     String?
  position    Int
  durationSec Int?
  isPreview   Boolean @default(false)

  // VISIBILITY FIX
  contentDraft Json      // instructor edits
  contentLive  Json       // students read

  publishedAt DateTime?
  removedAt   DateTime?   //  soft delete

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section     CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([sectionId, position])
  @@unique([sectionId, slug])
  @@map("lessons")
}


/* =========================
   MEDIA (ASSET-LEVEL CONTROL)
========================= */

model MediaAsset {
  id          Int @id @default(autoincrement())
  ownerId     Int
  type        MediaType
  storageKey String
  durationSec Int?
  status      MediaStatus @default(PROCESSING)

  owner       User @relation(fields: [ownerId], references: [id])

  createdAt   DateTime @default(now())

  @@map("media_assets")
}

/* =========================
   PUBLISH REQUESTS (ONLY TIER C)
========================= */

model CoursePublishRequest {
  id           Int @id @default(autoincrement())
  courseId     Int @unique
  type         CoursePublishType
  status       PublishRequestStatus @default(PENDING)
  notes        String?
  reviewedById Int?

  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewedBy   User?  @relation("ReviewedCourses", fields: [reviewedById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("course_publish_requests")
}

// Payment

model Order {
  id        String   @id @default(uuid())
  userId    Int
  courseId  Int
  amount    Int
  status    OrderStatus @default(PENDING)
  createdAt DateTime @default(now())
  invoice   Invoice[]

  user      User        @relation(fields: [userId], references: [id])
  course    Course      @relation(fields: [courseId], references: [id])

  @@map("orders")
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    Int
  courseId  Int
  createdAt DateTime @default(now())

  user      User        @relation(fields: [userId], references: [id])
  course    Course      @relation(fields: [courseId], references: [id])
  lessonProgress LessonProgress[]

  @@index([userId])
  @@unique([userId, courseId])
  @@map("enrollments")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

enum LessonProgressStatus {
  PENDING
  COMPLETED
}

model LessonProgress {
  id            Int          @id @default(autoincrement())

  lessonId      Int
  enrollmentId  String

  enrollment    Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson        Lesson      @relation(fields: [lessonId], references: [id],onDelete: Cascade)

  status        LessonProgressStatus
  @@index([enrollmentId])
  @@index([enrollmentId, status])
  @@unique([lessonId, enrollmentId])
  @@map("lesson_progress")
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  xenditId      String?
  orderId       String
  amount        Int
  status        InvoiceStatus
  expiresAt     DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
}

model InvoiceCounter {
  year Int @id
  seq  Int @default(0)
}